{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "product_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Name": {
      "type": "string"
    },
    "Description": {
      "type": "text"
    },
    "Price": {
      "type": "decimal"
    },
    "Category": {
      "type": "enumeration",
      "enum": [
        "Fungicides",
        "Insecticides",
        "Herbicides",
        "Nematicides ",
        "Acaricides",
        "Plant growth regulators",
        "Biostimulators"
      ]
    }
  }
}
